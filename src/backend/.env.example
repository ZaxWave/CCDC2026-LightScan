# ============================================
# LightScan Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in actual values
# ⚠️ SECURITY: Never commit .env to version control!

# ============================================
# Security Configuration (REQUIRED for Production)
# ============================================
# Generate a secure SECRET_KEY using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars

# JWT Algorithm (HS256, HS512, RS256, etc.)
ALGORITHM=HS256

# Access Token Expiration Time (in minutes)
# Default: 1440 (24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# Database Configuration (REQUIRED)
# ============================================
# ⚠️ IMPORTANT: Use strong passwords in production!

# SQLite (Development - Local Testing)
# DATABASE_URL=sqlite:///./app.db

# PostgreSQL (Production - Recommended)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Example: postgresql://admin:secure-password-here@db.example.com:5432/lightscandb
DATABASE_URL=postgresql://postgres:your-secure-password@localhost:5432/lightscandb

# ============================================
# Server Configuration
# ============================================
# API Port  
API_PORT=8000

# API Host (use 0.0.0.0 for Docker, 127.0.0.1 for local)
API_HOST=127.0.0.1

# ============================================
# Application Environment
# ============================================
# Options: development, staging, production
ENVIRONMENT=development

# Debug mode (False for production!)
DEBUG=True

# ============================================
# CORS Configuration
# ============================================
# IMPORTANT: Configure for your deployment!
# Development: Allow localhost and common dev ports
# Production: Explicitly whitelist your frontend domain
# Format: JSON list of allowed origins

# Local Development (multiple ports for testing)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:5173"]

# Production Example (replace with your domain)
# CORS_ORIGINS=["https://lightscan.example.com","https://www.lightscan.example.com"]

# Allow credentials with CORS
CORS_ALLOW_CREDENTIALS=true

# ============================================
# Logging Configuration
# ============================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional)
# LOG_FILE=logs/app.log

# ============================================
# AI Report (REQUIRED for report generation)
# ============================================
# DeepSeek API key — obtain from https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ============================================
# Model & Inference Configuration
# ============================================
# Path to ls-det model weights (default: models/weights/best.pt)
# MODEL_PATH=./models/weights/best.pt

# Whether to preload OCR engine at startup (true/false)
# Set false to speed up cold start if OCR mode is not needed
PRELOAD_OCR=true

# ============================================
# GPS Fallback Configuration
# ============================================
# Center coordinates used when uploaded images have no EXIF GPS data.
# Set this to the actual deployment city center so demo data lands
# on the correct map area. Default: Wuhan Guanggu (30.474, 114.414)
GPS_FALLBACK_LAT=30.474
GPS_FALLBACK_LNG=114.414

# ============================================
# File Upload Configuration
# ============================================
# Max video upload size (in MB)
# MAX_VIDEO_MB=500


